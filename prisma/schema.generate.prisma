generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma_next"
}

datasource db {
  provider = "postgresql"
}

enum CycleStatus {
  ACTIVE
  COMPLETED
}

enum FeedType {
  STARTER
  GROWER
  FINISHER
}

enum FeedInventoryMovementType {
  PURCHASE
  CONSUMPTION
  ADJUSTMENT
}

enum FeedInventoryReferenceType {
  FEED_PURCHASE
  DAILY_LOG
  MANUAL
  SYSTEM
}

enum ExpenseCategory {
  CHICKS
  FEED
  MEDICATION
  LABOR
  ELECTRICITY
  TRANSPORT
  MISC
  OTHER
}

enum ExpenseSourceType {
  MANUAL
  FEED_PURCHASE
  MEDICATION_LOG
  SYSTEM
}

enum Role {
  ADMIN
}

// Recommended: store stable English codes in DB.
// Display Arabic labels in the frontend.
enum DosageUnit {
  SPOON
  GRAM
  ML
  CM
}

enum DosagePerUnit {
  LITER
  BIRD
  KG
}

model Cycle {
  id String @id @default(uuid()) @db.Uuid

  name      String
  startDate DateTime    @map("start_date") @db.Date
  endDate   DateTime?   @map("end_date") @db.Date
  status    CycleStatus @default(ACTIVE)

  initialBirds Int @map("initial_birds")

  chickPrice                Decimal @map("chick_price") @db.Decimal(12, 2)
  expectedFinalWeightKg     Decimal @map("expected_final_weight_kg") @db.Decimal(10, 3)
  expectedSellingPricePerKg Decimal @map("expected_selling_price_per_kg") @db.Decimal(12, 2)
  expectedRemainingCost     Decimal @default(0) @map("expected_remaining_cost") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  feedPurchases          FeedPurchase[]
  feedInventoryMovements FeedInventoryMovement[]
  feedInventoryBalances  FeedInventoryBalance[]
  dailyLogs              DailyLog[]
  expenses               Expense[]
  medicationLogs         MedicationLog[]
  sales                  Sale[]
  weightLogs             WeightLog[]

  @@map("cycles")
}

model User {
  id String @id @default(uuid()) @db.Uuid

  email        String @unique
  passwordHash String @map("password_hash")
  role         Role   @default(ADMIN)

  passwordChangedAt DateTime  @map("password_changed_at")
  lastLoginAt       DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshSessions RefreshSession[]

  @@map("users")
}

model RefreshSession {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  familyId  String @map("family_id") @db.Uuid
  tokenHash String @unique @map("token_hash")

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  replacedBySessionId String?         @unique @map("replaced_by_session_id") @db.Uuid
  replacedBySession   RefreshSession? @relation("RefreshSessionReplacement", fields: [replacedBySessionId], references: [id])
  previousSession     RefreshSession? @relation("RefreshSessionReplacement")

  lastUsedAt DateTime? @map("last_used_at")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt])
  @@index([familyId, revokedAt])
  @@map("refresh_sessions")
}

model FeedPurchase {
  id String @id @default(uuid()) @db.Uuid

  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  purchaseDate DateTime @map("purchase_date") @db.Date
  feedType     FeedType @map("feed_type")

  quantityKg Decimal @map("quantity_kg") @db.Decimal(10, 2)
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cycleId])
  @@index([cycleId, purchaseDate])
  @@map("feed_purchases")
}

model FeedInventoryMovement {
  id String @id @default(uuid()) @db.Uuid

  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  movementDate DateTime @map("movement_date") @db.Date

  feedType     FeedType                  @map("feed_type")
  movementType FeedInventoryMovementType @map("movement_type")

  quantityKg Decimal @map("quantity_kg") @db.Decimal(10, 2)

  referenceType FeedInventoryReferenceType? @map("reference_type")
  referenceId   String?                     @map("reference_id") @db.Uuid

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cycleId])
  @@index([cycleId, movementDate])
  @@index([referenceType, referenceId])
  @@map("feed_inventory_movements")
}

model FeedInventoryBalance {
  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  feedType FeedType @map("feed_type")

  quantityKg Decimal @default(0) @map("quantity_kg") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([cycleId, feedType])
  @@index([cycleId])
  @@map("feed_inventory_balances")
}

model DailyLog {
  id String @id @default(uuid()) @db.Uuid

  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  deaths         Int      @default(0)
  feedType       FeedType @default(STARTER) @map("feed_type")
  feedConsumedKg Decimal  @default(0) @map("feed_consumed_kg") @db.Decimal(10, 2)

  temperature         Decimal? @db.Decimal(5, 2)
  humidity            Decimal? @db.Decimal(5, 2)
  waterConsumedLiters Decimal? @map("water_consumed_liters") @db.Decimal(10, 2)

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cycleId, date])
  @@index([cycleId])
  @@index([cycleId, date])
  @@map("daily_logs")
}

model Expense {
  id String @id @default(uuid()) @db.Uuid

  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  expenseDate DateTime        @map("expense_date") @db.Date
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)

  description String?

  sourceType ExpenseSourceType? @map("source_type")
  sourceId   String?            @map("source_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cycleId])
  @@index([cycleId, expenseDate])
  @@index([sourceType, sourceId])
  @@map("expenses")
}

model MedicationLog {
  id String @id @default(uuid()) @db.Uuid

  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  medicineName String @map("medicine_name")

  dosageAmount    Decimal       @map("dosage_amount") @db.Decimal(10, 2)
  dosageUnit      DosageUnit    @map("dosage_unit")
  dosagePerAmount Decimal       @default(1) @map("dosage_per_amount") @db.Decimal(10, 2)
  dosagePerUnit   DosagePerUnit @map("dosage_per_unit")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cycleId])
  @@index([cycleId, date])
  @@map("medication_logs")
}

model Sale {
  id String @id @default(uuid()) @db.Uuid

  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  saleDate DateTime @map("sale_date") @db.Date

  birdsSold Int @map("birds_sold")

  totalWeightKg Decimal @map("total_weight_kg") @db.Decimal(10, 3)
  pricePerKg    Decimal @map("price_per_kg") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cycleId])
  @@index([cycleId, saleDate])
  @@map("sales")
}

model WeightLog {
  id String @id @default(uuid()) @db.Uuid

  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  sampleSize      Int     @map("sample_size")
  averageWeightKg Decimal @map("average_weight_kg") @db.Decimal(10, 3)

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cycleId, date])
  @@index([cycleId])
  @@index([cycleId, date])
  @@map("weight_logs")
}
